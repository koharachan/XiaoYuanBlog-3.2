---
import { siteConfig, sponsorConfig } from "@/config";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
import Icon from "@/components/common/Icon.astro";
import GateIcon from "@/icons/gate.svg?raw";
import ECnyIcon from "@/icons/e-cny.svg?raw";
import TronIcon from "@/icons/tron.svg?raw";
import OkxIcon from "@/icons/okx.svg?raw";
import Erc20Icon from "@/icons/erc20.svg?raw";

if (!siteConfig.pages.sponsor) {
	return Astro.redirect("/404/");
}

const title = sponsorConfig.title || i18n(I18nKey.sponsorTitle);
const description = sponsorConfig.description || i18n(I18nKey.sponsorDescription);
const enabledMethods = sponsorConfig.methods.filter((m) => m.enabled);
const customSvgMap: Record<string, string> = {
	"e-cny": ECnyIcon,
	"gate": GateIcon,
	"tron": TronIcon,
	"okx": OkxIcon,
	"erc20": Erc20Icon,
};

const hasQuickEntry = enabledMethods.length >= 3;
const quickMethods = ["微信支付", "支付宝", "PayPal"];
const quickList = hasQuickEntry
	? enabledMethods.filter((m) => quickMethods.some((q) => m.name.includes(q)))
	: [];
---

<MainGridLayout title={title} description={description}>
  <div class="w-full max-w-3xl mx-auto pay-page pt-6 pb-8 px-4 sm:px-6 rounded-2xl bg-[var(--card-bg-transparent)] backdrop-blur-md" data-pay-page>

    <!-- 头部 -->
    <header class="mb-10 onload-animation">
      <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-2">{title}</h1>
      {description && (
        <p class="text-sm text-neutral-500 dark:text-neutral-400">{description}</p>
      )}
    </header>

    <!-- 快捷入口 — 桌面端：图标组 / 移动端：大按钮 -->
    {quickList.length > 0 && (
      <div class="mb-10 onload-animation" style="animation-delay: 80ms">
        <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500 mb-3">快速入口</p>
        <div class="flex flex-wrap gap-2.5">
          {quickList.map((m) => (
            <a
              href={`#method-${m.name}`}
              class="group flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-[var(--primary)]/40 hover:shadow-sm hover:-translate-y-px transition-all duration-200 font-medium text-sm text-neutral-700 dark:text-neutral-300"
            >
              <span class="w-4 h-4 flex-shrink-0 text-neutral-500 dark:text-neutral-400 group-hover:text-[var(--primary)] transition-colors duration-200">
                {customSvgMap[m.icon || ""] ? (
                  <span class="w-4 h-4 inline-block" set:html={customSvgMap[m.icon || ""]} />
                ) : (
                  m.icon ? <Icon icon={m.icon} size="sm" /> : null
                )}
              </span>
              <span>{m.name}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- 收款方式卡片 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {enabledMethods.map((method, index) => (
        <div
          id={`method-${method.name}`}
          class="group onload-animation card-base flex flex-col p-5 scroll-mt-24"
          style={`animation-delay: ${120 + index * 60}ms`}
        >
          <!-- 图标 + 名称 -->
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--primary)]/20 transition-colors duration-300">
              {customSvgMap[method.icon || ""] ? (
                <span class="w-4.5 h-4.5 text-[var(--primary)]" set:html={customSvgMap[method.icon || ""]} />
              ) : (
                method.icon ? <Icon icon={method.icon} size="base" class="text-[var(--primary)]" /> : null
              )}
            </div>
            <div>
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100 text-sm">{method.name}</h3>
              {method.description && (
                <p class="text-[11px] text-neutral-400 dark:text-neutral-500 mt-0.5">{method.description}</p>
              )}
            </div>
          </div>

          <!-- 二维码区域 -->
          {method.qrCode && (
            <div class="relative w-full max-w-[180px] mx-auto mb-3">
              <div class="aspect-square bg-white rounded-xl p-3 shadow-sm border border-neutral-100 dark:border-neutral-800 group-hover:shadow-md transition-shadow duration-300">
                <img
                  src={method.qrCode}
                  alt={`${method.name} 收款码`}
                  class="w-full h-full object-contain rounded-lg"
                  loading="lazy"
                  crossorigin="anonymous"
                />
              </div>
            </div>
          )}

          <!-- 钱包地址 -->
          {method.wallet && (
            <div class="mb-3 p-3 rounded-lg bg-neutral-50 dark:bg-neutral-900/60 border border-neutral-100 dark:border-neutral-800">
              <p class="text-[10px] uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-1">Address</p>
              <code class="text-[11px] text-neutral-600 dark:text-neutral-400 break-all font-mono leading-relaxed select-all">{method.wallet}</code>
              <button
                class="mt-2 text-[11px] flex items-center gap-1.5 text-[var(--primary)] hover:underline underline-offset-2"
                data-copy={method.wallet}
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span>复制</span>
              </button>
            </div>
          )}

          <!-- 操作区 -->
          <div class="mt-auto flex flex-wrap gap-2"
            data-pay-method={method.name}
            data-pay-link={method.link || ""}
            data-pay-qr={method.qrCode || ""}
            data-pay-wallet={method.wallet || ""}
          >
            <!-- 支付宝：桌面显示打开支付宝，移动端显示唤起支付宝 -->
            {method.name.includes("支付宝") && method.link && (
              <a
                href={method.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg text-sm font-semibold bg-[#1677ff] text-white hover:opacity-90 active:scale-95 transition-all shadow-sm"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.3 15.1c-.4.3-.8.5-1.3.6-.5.1-1 .1-1.5 0-.6-.1-1-.4-1.3-.9-.2-.3-.3-.7-.3-1.1 0-.4.1-.8.3-1.1.3-.5.7-.8 1.3-.9.5-.1 1-.1 1.5 0l1.3.6v2.8zm7.4 0c-.4.3-.8.5-1.3.6-.5.1-1 .1-1.5 0-.6-.1-1-.4-1.3-.9-.2-.3-.3-.7-.3-1.1 0-.4.1-.8.3-1.1.3-.5.7-.8 1.3-.9.5-.1 1-.1 1.5 0l1.3.6v2.8zM12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 15.5c-1.2 0-2.3-.4-3.2-1l-1.6 1.6-1.4-1.4 1.6-1.6c-.6-.9-1-2-1-3.2 0-3 2.4-5.4 5.4-5.4s5.4 2.4 5.4 5.4-2.4 5.4-5.4 5.4z"/></svg>
                打开支付宝
              </a>
            )}
            {method.name.includes("支付宝") && !method.link && (
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                用支付宝扫一扫
              </span>
            )}

            <!-- 微信支付 -->
            {method.name.includes("微信") && method.link && (
              <a
                href={method.link}
                class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg text-sm font-semibold bg-[#07c160] text-white hover:opacity-90 active:scale-95 transition-all shadow-sm"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.7 14.3c-.5 0-1 .4-1 .9s.4.9 1 .9 1-.4 1-.9-.4-.9-1-.9zm6.6 0c-.5 0-1 .4-1 .9s.4.9 1 .9 1-.4 1-.9-.4-.9-1-.9zM2 12C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 10-10 10S2 17.5 2 12zm16.5-2.8c-1.8-2.3-5.3-2.7-7.8-1.4-.3.2-.5.4-.7.6-.1.1-.1.2-.1.4 0 .2.1.3.3.3l.4.1c.3.1.7.2 1 .4 1.3.7 2.3 1.7 2.8 3.1.1.2.2.4.2.6 0 .2.1.4.3.4.3.1.5.1.8.1 1.8-.1 3.4-1.5 3.6-3.3.2-1.2-.2-2.4-.8-3.3z"/></svg>
                唤起微信支付
              </a>
            )}
            {method.name.includes("微信") && (
              <span class="text-[10px] text-neutral-400 dark:text-neutral-500 w-full">桌面用户请截图后用微信扫一扫</span>
            )}

            <!-- QQ支付 -->
            {method.name.includes("QQ") && (
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 w-full justify-center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm1.5 13c-.3.2-.7.4-1.1.4-.4 0-.8-.2-1.1-.4-.6-.4-.9-1-.9-1.7 0-.7.3-1.3.9-1.7.3-.2.7-.4 1.1-.4.4 0 .8.2 1.1.4.6.4.9 1 .9 1.7 0 .7-.3 1.3-.9 1.7z"/></svg>
                用QQ扫一扫
              </span>
            )}

            <!-- PayPal -->
            {method.name === "PayPal" && method.link && (
              <a
                href={method.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg text-sm font-semibold bg-[#0070ba] text-white hover:opacity-90 active:scale-95 transition-all shadow-sm"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7.076 21.337H2.47a.641.641 0 01-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797H8.555c-.525 0-.973.382-1.057.903l-.043.272c-.032.203-.09.407-.143.607L7.076 21.336z"/></svg>
                前往 PayPal
              </a>
            )}

            <!-- 数字人民币 -->
            {method.name.includes("数字人民币") && (
              <span class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium border border-neutral-200 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 w-full justify-center">
                用数字人民币 App 扫一扫
              </span>
            )}

            <!-- 通用：有 link 不是以上特殊情况 -->
            {!method.name.includes("支付宝") && !method.name.includes("微信") && !method.name.includes("QQ") && method.name !== "PayPal" && !method.name.includes("数字人民币") && method.link && (
              <a
                href={method.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-medium bg-[var(--primary)] text-white hover:opacity-90 active:scale-95 transition-all shadow-sm shadow-[var(--primary)]/20"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                打开
              </a>
            )}

            <!-- Gate.io / OKX 无 link 仅扫码 -->
            {!method.link && !method.wallet && !method.name.includes("支付宝") && !method.name.includes("微信") && !method.name.includes("QQ") && !method.name.includes("数字人民币") && (
              <span class="text-[11px] text-neutral-400">请扫描上方二维码</span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="h-12"></div>

  </div>
</MainGridLayout>

<script>
    document.body.classList.remove("enable-banner");
    const bw = document.getElementById("banner-wrapper");
    if (bw) bw.classList.add("hidden");

  document.querySelectorAll("[data-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") || "";
      try {
        await navigator.clipboard.writeText(text);
        const span = btn.querySelector("span");
        const orig = span?.textContent || "";
        if (span) span.textContent = "已复制 ✓";
        btn.classList.add("!text-green-600", "!border-green-400");
        setTimeout(() => {
          if (span) span.textContent = orig;
          btn.classList.remove("!text-green-600", "!border-green-400");
        }, 2000);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
      }
    });
  });
</script>
