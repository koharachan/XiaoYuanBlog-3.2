---
import { siteConfig, sponsorConfig } from "@/config";
import { i18n } from "@/i18n/translation";
import I18nKey from "@/i18n/i18nKey";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
import Icon from "@/components/common/Icon.astro";
import GateIcon from "@/icons/gate.svg?raw";
import ECnyIcon from "@/icons/e-cny.svg?raw";
import TronIcon from "@/icons/tron.svg?raw";
import OkxIcon from "@/icons/okx.svg?raw";
import Erc20Icon from "@/icons/erc20.svg?raw";

if (!siteConfig.pages.sponsor) {
	return Astro.redirect("/404/");
}

const title = sponsorConfig.title || i18n(I18nKey.sponsorTitle);
const description = sponsorConfig.description || i18n(I18nKey.sponsorDescription);
const enabledMethods = sponsorConfig.methods.filter((m) => m.enabled);
const customSvgMap: Record<string, string> = {
	"e-cny": ECnyIcon,
	"gate": GateIcon,
	"tron": TronIcon,
	"okx": OkxIcon,
	"erc20": Erc20Icon,
};

const hasQuickEntry = enabledMethods.length >= 4;
const quickMethods = hasQuickEntry ? enabledMethods.slice(0, 4) : [];
---

<MainGridLayout title={title} description={description}>
  <div class="w-full max-w-3xl mx-auto">

    <!-- 头部 -->
    <header class="mb-12 onload-animation">
      <h1 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 mb-2">{title}</h1>
      {description && (
        <p class="text-sm text-neutral-500 dark:text-neutral-400">{description}</p>
      )}
    </header>

    <!-- 快捷入口 -->
    {hasQuickEntry && (
      <div class="mb-12 onload-animation" style="animation-delay: 80ms">
        <p class="text-[11px] font-semibold uppercase tracking-[0.15em] text-neutral-400 dark:text-neutral-500 mb-3">快速入口</p>
        <div class="flex flex-wrap gap-2.5">
          {quickMethods.map((m) => (
            <a
              href={m.link && m.link.startsWith("http") ? m.link : `#method-${m.name}`}
              target={m.link?.startsWith("http") ? "_blank" : undefined}
              rel="noopener noreferrer"
              class="group flex items-center gap-2 px-4 py-2.5 rounded-lg bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-[var(--primary)]/40 hover:shadow-sm hover:-translate-y-px transition-all duration-200 font-medium text-sm text-neutral-700 dark:text-neutral-300"
            >
              <span class="w-4 h-4 flex-shrink-0 text-neutral-500 dark:text-neutral-400 group-hover:text-[var(--primary)] transition-colors duration-200">
                {customSvgMap[m.icon || ""] ? (
                  <span class="w-4 h-4 inline-block" set:html={customSvgMap[m.icon || ""]} />
                ) : (
                  m.icon ? <Icon icon={m.icon} size="sm" /> : null
                )}
              </span>
              <span>{m.name.split("-")[0]}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- 收款方式卡片网格 -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {enabledMethods.map((method, index) => (
        <div
          id={`method-${method.name}`}
          class="group onload-animation card-base flex flex-col p-5 scroll-mt-24"
          style={`animation-delay: ${120 + index * 60}ms`}
        >
          <!-- 图标 + 名称 -->
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-[var(--primary)]/10 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--primary)]/20 transition-colors duration-300">
              {customSvgMap[method.icon || ""] ? (
                <span class="w-4.5 h-4.5 text-[var(--primary)]" set:html={customSvgMap[method.icon || ""]} />
              ) : (
                method.icon ? <Icon icon={method.icon} size="base" class="text-[var(--primary)]" /> : null
              )}
            </div>
            <div>
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-100 leading-tight text-sm">{method.name}</h3>
              {method.description && (
                <p class="text-[11px] text-neutral-400 dark:text-neutral-500 mt-0.5">{method.description}</p>
              )}
            </div>
          </div>

          <!-- 二维码 -->
          {method.qrCode && (
            <div class="relative w-full max-w-[150px] mx-auto aspect-square bg-white rounded-xl p-2.5 shadow-sm mb-3 border border-neutral-100 dark:border-neutral-800 group-hover:shadow-md transition-shadow duration-300">
              <img src={url(method.qrCode)} alt={method.name} class="w-full h-full object-contain rounded-md" loading="lazy" />
            </div>
          )}

          <!-- 钱包地址 -->
          {method.wallet && (
            <div class="mb-3 p-3 rounded-lg bg-neutral-50 dark:bg-neutral-900/60 border border-neutral-100 dark:border-neutral-800">
              <p class="text-[10px] uppercase tracking-widest text-neutral-400 dark:text-neutral-500 mb-1">Address</p>
              <code class="text-[11px] text-neutral-600 dark:text-neutral-400 break-all font-mono leading-relaxed select-all">{method.wallet}</code>
              <button
                class="mt-2 text-[11px] flex items-center gap-1.5 text-[var(--primary)] hover:underline underline-offset-2"
                data-copy={method.wallet}
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                <span>复制</span>
              </button>
            </div>
          )}

          <!-- 操作 -->
          <div class="mt-auto flex gap-2 flex-wrap">
            {method.link && (
              <a
                href={method.link}
                target={method.link.startsWith("http") ? "_blank" : "_self"}
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-[13px] font-medium bg-[var(--primary)] text-white hover:opacity-90 active:scale-95 transition-all shadow-sm shadow-[var(--primary)]/20"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                前往支付
              </a>
            )}
            {method.wallet && (
              <button
                data-copy={method.wallet}
                class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg text-[13px] font-medium border border-neutral-200 dark:border-neutral-700 text-neutral-600 dark:text-neutral-400 hover:bg-neutral-50 dark:hover:bg-neutral-800 active:scale-95 transition-all"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                复制
              </button>
            )}
            {!method.link && !method.wallet && (
              <span class="text-[11px] text-neutral-400">扫描二维码支付</span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="h-10"></div>

  </div>
</MainGridLayout>

<script>
  document.querySelectorAll("[data-copy]").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.getAttribute("data-copy") || "";
      try {
        await navigator.clipboard.writeText(text);
        const span = btn.querySelector("span");
        const orig = span?.textContent || "";
        if (span) span.textContent = "已复制 ✓";
        btn.classList.add("!text-green-600", "!border-green-400");
        setTimeout(() => {
          if (span) span.textContent = orig;
          btn.classList.remove("!text-green-600", "!border-green-400");
        }, 2000);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
      }
    });
  });
</script>
